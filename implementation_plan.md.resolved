## 数据模型草案（待确认后细化）

```mermaid
erDiagram
    PROJECT ||--o{ SHIP : contains
    SHIP ||--o{ INSPECTION_ITEM : has
    INSPECTION_ITEM ||--o{ INSPECTION_RESULT : records
    INSPECTION_ITEM ||--o{ COMMENT : has
    USER ||--o{ INSPECTION_RESULT : submits
    USER ||--o{ USER_PROJECT : assigned_to
    PROJECT ||--o{ USER_PROJECT : has_members
    ROLE ||--o{ USER : has

    PROJECT {
        int id PK
        string name
        string code
        string status
        date start_date
        date end_date
    }

    SHIP {
        int id PK
        int project_id FK
        string hull_number
        string ship_type
        string status
    }

    INSPECTION_ITEM {
        int id PK
        int ship_id FK
        string item_name
        string discipline
        date planned_date
        string status
        string standard_ref
        int version
    }

    INSPECTION_RESULT {
        int id PK
        int inspection_item_id FK
        int inspector_id FK
        string result
        text opinion
        datetime submitted_at
        int version
    }

    USER {
        int id PK
        string username
        string email
        string password_hash
        int role_id FK
        bool is_active
    }

    COMMENT {
        int id PK
        int inspection_item_id FK
        int user_id FK
        text content
        datetime created_at
    }
```

