{
  "name": "nbins",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @nbins/web dev",
    "dev:api": "pnpm --filter @nbins/api dev",
    "dev:api:d1": "pnpm d1:bootstrap && cross-env pnpm --filter @nbins/api exec wrangler dev --local --var D1_DRIVER:d1 --persist-to .wrangler/state",
    "d1:gen": "pnpm --filter @nbins/api run gen:bootstrap-sql -- src/db/d1-bootstrap.sql",
    "d1:bootstrap": "pnpm d1:gen && pnpm --filter @nbins/api exec node scripts/bootstrap-local-d1.mjs",
    "test:api": "pnpm --filter @nbins/api test",
    "qa": "pnpm typecheck && pnpm build && pnpm test:api",
    "typecheck": "pnpm -r typecheck",
    "deploy:api": "pnpm --filter @nbins/api exec wrangler deploy",
    "deploy:web": "pnpm --filter @nbins/web run deploy",
    "deploy:all": "pnpm deploy:api && pnpm deploy:web"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  },
  "dependencies": {
    "@types/exceljs": "^1.3.2",
    "exceljs": "^4.4.0"
  }
}
