{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nbins-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-03",
  "dev": {
    "port": 8787
  },
  "d1_databases": [
    {
      "binding": "DB",
      // Set both values after `wrangler d1 create <name>`.
      "database_name": "nbins-local",
      "database_id": "214dd5f8-c591-4a68-9134-e763ac773428"
    }
  ],
  "vars": {
    "SQL_CONSOLE_SECRET": "pgnewbuilding"
  }
}